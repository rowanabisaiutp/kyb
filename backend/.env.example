# Desarrollo local (Docker Postgres)
DATABASE_URL=postgresql+asyncpg://kyb_dev:kyb_dev_pass@localhost:5432/kyb_dev

# Produccion (Fly.io) - se configura automaticamente via flyctl secrets
# DATABASE_URL=postgres://user:pass@host:5432/db

# AI - al menos una key requerida para extraccion de documentos
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Storage (Fly Tigris - se configura automaticamente)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL_S3=
BUCKET_NAME=kyb-documents

APP_ENV=development
